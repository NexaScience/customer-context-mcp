# LLM (required for brief generation & Q&A)
GEMINI_API_KEY=...

# Notion (required for Notion source)
# Integration: https://www.notion.so/profile/integrations
# IMPORTANT: share the integration with the pages you want searched
#   (Page ••• → Connections → add your integration). Notion search only returns
#   pages the integration can access, and it matches page TITLES (not body).
NOTION_TOKEN=secret_...
# Recommended for structured data: query specific databases instead of the
# title-only search. Rows are matched on title + ALL property values and the
# row body is included. Comma-separated database IDs (the 32-char id in the
# database URL: notion.so/<workspace>/<DB_ID>?v=...). Share each DB with the
# integration too.
# NOTION_DATABASE_IDS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Slack (required for Slack source)
# search.messages requires a USER token (xoxp-) with the search:read scope.
# A bot token (xoxb-) CANNOT call search (returns not_allowed_token_type).
# Create a user token: OAuth & Permissions → User Token Scopes → search:read.
SLACK_USER_TOKEN=xoxp-...
# Optional fallback (cannot search; only used if no user token is set):
# SLACK_BOT_TOKEN=xoxb-...

# Google Drive (required for Google Drive source)
# OAuth 2.0 client (Desktop app) credentials downloaded from Google Cloud Console.
# Place credentials.json next to .env (./credentials.json) and let the OAuth flow
# write token.json (./token.json) on first run.
