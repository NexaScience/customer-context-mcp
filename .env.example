# LLM (required for brief generation & Q&A)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# Notion (required for Notion source)
# Integration: https://www.notion.so/profile/integrations
NOTION_TOKEN=secret_...

# Slack (required for Slack source)
# Bot scopes: channels:history, channels:read, groups:history, groups:read,
#             im:history, mpim:history, search:read, users:read
SLACK_BOT_TOKEN=xoxb-...
# Optional: comma-separated channel IDs/names to restrict search
SLACK_CHANNELS=

# Google Drive (required for Google Drive source)
# OAuth 2.0 client (Desktop app) credentials downloaded from Google Cloud Console.
# Place credentials.json next to .env and let the OAuth flow write token.json on first run.
GOOGLE_CREDENTIALS_FILE=./credentials.json
GOOGLE_TOKEN_FILE=./token.json

# HTTP server
HOST=127.0.0.1
PORT=8787
# Comma-separated extra origins allowed by CORS (the configured PORT is always allowed)
ALLOWED_ORIGINS=
