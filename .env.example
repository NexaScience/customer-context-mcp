# LLM (required for brief generation & Q&A)
GEMINI_API_KEY=...

# Notion (required for Notion source)
# Integration: https://www.notion.so/profile/integrations
# IMPORTANT: share the integration with the pages/databases you want searched
#   (••• → Connections → add your integration). Notion only returns content the
#   integration can access. Databases shared with it are auto-discovered and
#   searched structurally (title + ALL property values + row body); standalone
#   pages fall back to the title-only search API.
NOTION_TOKEN=secret_...

# Slack (required for Slack source)
# Bot token (xoxb-). The Slack source scans the history of the channels the bot
# is a member of, so grant these Bot Token Scopes and invite the bot to the
# relevant channels (/invite @your-bot):
#   channels:read, groups:read      → list channels
#   channels:history, groups:history → read messages
SLACK_BOT_TOKEN=xoxb-...

# Google Drive (required for Google Drive source)
# OAuth 2.0 client (Desktop app) credentials downloaded from Google Cloud Console.
# Place credentials.json next to .env (./credentials.json) and let the OAuth flow
# write token.json (./token.json) on first run.
